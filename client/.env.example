# ──────────────────────────────────────────────
# AssetFlow — Supabase Environment Variables
# ──────────────────────────────────────────────
# Copy this file to `.env` and fill in your project values.
# These are exposed to the browser (VITE_ prefix) — they are
# safe to ship because RLS policies protect backend data.
#
# Find these at: https://supabase.com/dashboard → Settings → API
# ──────────────────────────────────────────────

# Supabase project URL (e.g. https://xyzcompany.supabase.co)
VITE_SUPABASE_URL=

# Supabase anonymous (public) API key
VITE_SUPABASE_ANON_KEY=

# Set to true to bypass Supabase and run the app entirely on local mock data
VITE_USE_MOCK_DATA=false

